[Unit]
Description=Oficina Mecânica - Backend API (json-server)
After=network.target

[Service]
Type=simple
User=www-data
WorkingDirectory=/var/www/oficina-mecanica
ExecStart=/usr/bin/npx json-server --watch db.json --port 3001
Restart=on-failure
RestartSec=10
StandardOutput=journal
StandardError=journal

# Recursos
MemoryMax=512M
CPUQuota=50%

[Install]
WantedBy=multi-user.target
